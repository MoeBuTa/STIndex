OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# MCP server public URL
MCP_BASE_URL=https://stindex.wenxiao.link

# ── Auth mode A: KAIAPlatform OAuth (recommended) ──────────────────────────
# Register STIndex as an OAuth Application in the KAIA Django admin first.
# Admin → Django OAuth Toolkit → Applications → Add
OIDC_DISCOVERY_URL=https://kaia.wenxiao.link/o/.well-known/openid-configuration
OIDC_CLIENT_ID=your_kaia_client_id_here
OIDC_CLIENT_SECRET=your_kaia_client_secret_here
OIDC_USE_INTROSPECTION=true
OIDC_VERIFY_SSL=true
OIDC_TIMEOUT=30

# ── Auth mode B: self-contained (no KAIA, fallback) ────────────────────────
# Used when OIDC_DISCOVERY_URL is not set. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# MCP_API_KEY=your_mcp_api_key_here
